// ==========================================
// CONFIGURACIÓN DE PRISMA
// ==========================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 0. NÚCLEO SAAS Y CATÁLOGOS BASE
// ==========================================
model Farm {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(100)
  owner             String?  @db.VarChar(100)
  registration_date DateTime @default(now())

  // Relaciones inversas (Requeridas por Prisma para navegar)
  employees            Employee[]
  locations            Location[]
  medicines            Medicine[]
  races                Race[]
  animals              Animal[]
  services             Service[]
  matings              Mating[]
  abortions            Abortion[]
  farrowings           Farrowing[]
  litters              Litter[]
  litter_movements     LitterMovement[]
  batches              Batch[]
  batch_locations      BatchLocation[]
  batch_movements      BatchMovement[]
  feed_phases          FeedPhase[]
  feed_inventories     FeedInventory[]
  batch_feedings       BatchFeeding[]
  medical_treatments   MedicalTreatment[]
  sales                Sale[]
  removal_reasons      RemovalReason[]
  piglet_death_reasons PigletDeathReason[]
  animal_removals      AnimalRemoval[]
}

model User {
  id         String     @id // Aquí guardaremos el UID único que genera Appwrite
  email      String     @unique @db.VarChar(255)
  name       String     @db.VarChar(100)
  created_at DateTime   @default(now())

  // Relación: Un usuario puede tener perfiles de empleado en muchas granjas
  employments Employee[]
}

model Employee {
  id      Int     @id @default(autoincrement())
  user_id String  // NUEVO: Conecta con el usuario global
  farm_id Int
  role    Role    @default(User)
  active  Boolean @default(true)

  farm                  Farm                    @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  matings               Mating[]
  abortions             Abortion[]
  farrowing_medications FarrowingMedication[]
  farrowing_employees   FarrowingEmployee[]
  litter_movements      LitterMovement[]
  batch_movements       BatchMovement[]
  batch_feedings        BatchFeeding[]
  medical_treatments    MedicalTreatment[]
  sales                 Sale[]

  @@unique([user_id, farm_id])
}

model Location {
  id          Int          @id @default(autoincrement())
  farm_id     Int
  name        String       @db.VarChar(100)
  type        LocationType
  capacity    Int?
  active      Boolean      @default(true)
  observation String?      @db.Text

  farm               Farm               @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  animals            Animal[]
  services           Service[]
  farrowings         Farrowing[]
  batch_locations    BatchLocation[]
  batch_movements    BatchMovement[]
  medical_treatments MedicalTreatment[]
}

model Medicine {
  id      Int     @id @default(autoincrement())
  farm_id Int
  name    String  @db.VarChar(100)
  active  Boolean @default(true)

  farm                  Farm                  @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  farrowing_medications FarrowingMedication[]
  medical_treatments    MedicalTreatment[]
}

// ==========================================
// 1. MÓDULO DE ANIMALES REPRODUCTORES
// ==========================================
model Race {
  id      Int     @id @default(autoincrement())
  farm_id Int
  name    String  @db.VarChar(100)
  active  Boolean @default(true)

  farm    Farm     @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  animals Animal[]
}

model Animal {
  id          Int        @id @default(autoincrement())
  farm_id     Int
  race_id     Int
  tag_number  String     @db.VarChar(50)
  type        AnimalType
  entry_date  DateTime   @db.Date
  born_date   DateTime?  @db.Date
  parity      Int?
  active      Boolean    @default(true)
  location_id Int?
  observation String?    @db.Text

  farm               Farm               @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  race               Race               @relation(fields: [race_id], references: [id])
  location           Location?          @relation(fields: [location_id], references: [id])
  removals           AnimalRemoval[]
  services           Service[]          @relation("SowServices")
  matings            Mating[]           @relation("BoarMatings")
  medical_treatments MedicalTreatment[]
  sales              Sale[]
}

model RemovalReason {
  id      Int     @id @default(autoincrement())
  farm_id Int
  name    String  @db.VarChar(100)
  active  Boolean @default(true)

  farm      Farm            @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  removals  AnimalRemoval[]
  abortions Abortion[]
}

model AnimalRemoval {
  id          Int         @id @default(autoincrement())
  animal_id   Int
  farm_id     Int
  date        DateTime    @db.Date
  type        RemovalType
  reason_id   Int
  observation String?     @db.Text

  animal Animal        @relation(fields: [animal_id], references: [id], onDelete: Cascade)
  farm   Farm          @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  reason RemovalReason @relation(fields: [reason_id], references: [id])
}

// ==========================================
// 2. MÓDULO REPRODUCTIVO
// ==========================================
model Service {
  id                      Int           @id @default(autoincrement())
  farm_id                 Int
  sow_id                  Int
  start_date              DateTime      @db.Date
  location_id             Int?
  expected_farrowing_date DateTime?     @db.Date
  status                  ServiceStatus @default(Pending)

  farm      Farm       @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  sow       Animal     @relation("SowServices", fields: [sow_id], references: [id], onDelete: Cascade)
  location  Location?  @relation(fields: [location_id], references: [id])
  matings   Mating[]
  abortion  Abortion?  // Relación 1 a 1 opcional
  farrowing Farrowing? // Relación 1 a 1 opcional
}

model Mating {
  id          Int        @id @default(autoincrement())
  service_id  Int
  farm_id     Int
  boar_id     Int
  employee_id Int
  date        DateTime   @db.Date
  shift       Shift
  type        MatingType

  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)
  farm     Farm     @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  boar     Animal   @relation("BoarMatings", fields: [boar_id], references: [id])
  employee Employee @relation(fields: [employee_id], references: [id])
}

model Abortion {
  id          Int      @id @default(autoincrement())
  farm_id     Int
  service_id  Int      @unique // Prisma requiere @unique para relaciones 1 a 1
  reason_id   Int
  employee_id Int
  date        DateTime @db.Date
  shift       Shift
  observation String?  @db.Text

  farm     Farm          @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  service  Service       @relation(fields: [service_id], references: [id], onDelete: Cascade)
  reason   RemovalReason @relation(fields: [reason_id], references: [id])
  employee Employee      @relation(fields: [employee_id], references: [id])
}

// ==========================================
// 3. MÓDULO DE MATERNIDAD
// ==========================================
model Farrowing {
  id                  Int       @id @default(autoincrement())
  farm_id             Int
  service_id          Int       @unique
  location_id         Int
  start_time          DateTime
  end_time            DateTime?
  live_males          Int       @default(0)
  live_females        Int       @default(0)
  stillborn           Int       @default(0)
  mummified           Int       @default(0)
  total_weight_kg     Decimal   @db.Decimal(6, 2)
  manual_intervention Boolean   @default(false)
  observation         String?   @db.Text

  farm        Farm                  @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  service     Service               @relation(fields: [service_id], references: [id], onDelete: Cascade)
  location    Location              @relation(fields: [location_id], references: [id])
  medications FarrowingMedication[]
  employees   FarrowingEmployee[]
  litter      Litter?               // Relación 1 a 1
}

model FarrowingMedication {
  id           Int      @id @default(autoincrement())
  farrowing_id Int
  medicine_id  Int
  employee_id  Int
  dose         Decimal  @db.Decimal(6, 2)
  time_applied DateTime

  farrowing Farrowing @relation(fields: [farrowing_id], references: [id], onDelete: Cascade)
  medicine  Medicine  @relation(fields: [medicine_id], references: [id])
  employee  Employee  @relation(fields: [employee_id], references: [id])
}

model FarrowingEmployee {
  id                 Int               @id @default(autoincrement())
  farrowing_id       Int
  employee_id        Int
  participation_type ParticipationType

  farrowing Farrowing @relation(fields: [farrowing_id], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employee_id], references: [id])
}

model Litter {
  id              Int          @id @default(autoincrement())
  farm_id         Int
  farrowing_id    Int          @unique
  current_piglets Int          @default(0)
  status          LitterStatus @default(Nursing)

  farm               Farm               @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  farrowing          Farrowing          @relation(fields: [farrowing_id], references: [id], onDelete: Cascade)
  movements_as_main  LitterMovement[]   @relation("MainLitter")
  movements_as_rel   LitterMovement[]   @relation("RelatedLitter")
  medical_treatments MedicalTreatment[]
}

model PigletDeathReason {
  id      Int     @id @default(autoincrement())
  farm_id Int
  name    String  @db.VarChar(100)
  active  Boolean @default(true)

  farm             Farm             @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  litter_movements LitterMovement[]
}

model LitterMovement {
  id                   Int                @id @default(autoincrement())
  farm_id              Int
  litter_id            Int
  related_litter_id    Int?
  type                 LitterMovementType
  quantity             Int
  weight_kg            Decimal?           @db.Decimal(6, 2)
  destination_batch_id Int?
  date                 DateTime
  reason_id            Int?
  employee_id          Int
  observation          String?            @db.Text

  farm              Farm               @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  litter            Litter             @relation("MainLitter", fields: [litter_id], references: [id], onDelete: Cascade)
  related_litter    Litter?            @relation("RelatedLitter", fields: [related_litter_id], references: [id])
  destination_batch Batch?             @relation(fields: [destination_batch_id], references: [id])
  reason            PigletDeathReason? @relation(fields: [reason_id], references: [id])
  employee          Employee           @relation(fields: [employee_id], references: [id])
}

// ==========================================
// 4. MÓDULO DE ENGORDE Y ALIMENTACIÓN
// ==========================================
model Batch {
  id                       Int         @id @default(autoincrement())
  farm_id                  Int
  identifier               String      @db.VarChar(50)
  start_date               DateTime    @db.Date
  current_head_count       Int         @default(0)
  estimated_average_weight Decimal?    @db.Decimal(6, 2)
  status                   BatchStatus @default(Active)

  farm               Farm               @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  locations          BatchLocation[]
  movements          BatchMovement[]
  feedings           BatchFeeding[]
  medical_treatments MedicalTreatment[]
  sales              Sale[]
  litter_origins     LitterMovement[] // Entradas desde maternidad
}

model BatchLocation {
  id                 Int @id @default(autoincrement())
  farm_id            Int
  batch_id           Int
  location_id        Int
  current_head_count Int @default(0)

  farm     Farm     @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  batch    Batch    @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  location Location @relation(fields: [location_id], references: [id])
}

model BatchMovement {
  id              Int               @id @default(autoincrement())
  farm_id         Int
  batch_id        Int
  location_id     Int?
  type            BatchMovementType
  quantity        Int
  total_weight_kg Decimal?          @db.Decimal(8, 2)
  date            DateTime
  reason          String?           @db.VarChar(255)
  employee_id     Int

  farm     Farm      @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  batch    Batch     @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [location_id], references: [id])
  employee Employee  @relation(fields: [employee_id], references: [id])
}

model FeedPhase {
  id      Int     @id @default(autoincrement())
  farm_id Int
  name    String  @db.VarChar(100)
  active  Boolean @default(true)

  farm        Farm            @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  feedings    BatchFeeding[]
  inventories FeedInventory[]
}

model FeedInventory {
  id               Int     @id @default(autoincrement())
  farm_id          Int
  feed_phase_id    Int
  stock_kg         Decimal @db.Decimal(10, 2)
  minimum_stock_kg Decimal @db.Decimal(10, 2)

  farm       Farm      @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  feed_phase FeedPhase @relation(fields: [feed_phase_id], references: [id], onDelete: Cascade)
}

model BatchFeeding {
  id            Int      @id @default(autoincrement())
  farm_id       Int
  batch_id      Int
  feed_phase_id Int
  employee_id   Int
  quantity_kg   Decimal  @db.Decimal(8, 2)
  date          DateTime @db.Date

  farm       Farm      @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  batch      Batch     @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  feed_phase FeedPhase @relation(fields: [feed_phase_id], references: [id])
  employee   Employee  @relation(fields: [employee_id], references: [id])
}

// ==========================================
// 5. MÓDULO DE SALUD (HOSPITAL / GENERAL)
// ==========================================
model MedicalTreatment {
  id          Int      @id @default(autoincrement())
  farm_id     Int
  medicine_id Int
  animal_id   Int?
  batch_id    Int?
  litter_id   Int?     // Añadido para medicar lechones en maternidad
  location_id Int?
  employee_id Int
  dose        Decimal  @db.Decimal(6, 2)
  date        DateTime
  observation String?  @db.Text

  farm     Farm      @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  medicine Medicine  @relation(fields: [medicine_id], references: [id])
  animal   Animal?   @relation(fields: [animal_id], references: [id])
  batch    Batch?    @relation(fields: [batch_id], references: [id])
  litter   Litter?   @relation(fields: [litter_id], references: [id])
  location Location? @relation(fields: [location_id], references: [id])
  employee Employee  @relation(fields: [employee_id], references: [id])
}

// ==========================================
// 6. MÓDULO DE VENTAS
// ==========================================
model Sale {
  id              Int      @id @default(autoincrement())
  farm_id         Int
  batch_id        Int?
  animal_id       Int?
  client_name     String   @db.VarChar(100)
  quantity        Int
  total_weight_kg Decimal  @db.Decimal(10, 2)
  total_price     Decimal  @db.Decimal(12, 2)
  date            DateTime @db.Date
  invoice_number  String?  @db.VarChar(50)
  employee_id     Int

  farm     Farm     @relation(fields: [farm_id], references: [id], onDelete: Cascade)
  batch    Batch?   @relation(fields: [batch_id], references: [id])
  animal   Animal?  @relation(fields: [animal_id], references: [id])
  employee Employee @relation(fields: [employee_id], references: [id])
}

// ==========================================
// ENUMS (Listas de valores estáticos)
// ==========================================
enum Role {
  Administrator
  User
  Veterinarian
  Owner
}

enum LocationType {
  Gestation
  Farrowing
  Nursery
  Fattening
  Quarantine
  Hospital
}

enum AnimalType {
  Sow
  Boar
}

enum RemovalType {
  Dead
  Disposal
  Sacrificed
}

enum ServiceStatus {
  Pending
  Pregnant
  Failed
  Aborted
  Farrowed
}

enum Shift {
  Morning
  Afternoon
  Night
}

enum MatingType {
  Artificial
  Natural
}

enum ParticipationType {
  Primary
  Assistant
  Relief
}

enum LitterStatus {
  Nursing
  Weaned
}

enum LitterMovementType {
  Adoption
  Donation
  Death
  PartialWeaning
  FullWeaning
}

enum BatchStatus {
  Active
  Sold
  Merged
}

enum BatchMovementType {
  Entry
  Death
  Sale
  Transfer
}